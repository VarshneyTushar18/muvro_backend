    },
    "InstagramUrl": {
      "type": "string"
    },
    "facebookUrl": {
      "type": "string"
    },
    "xUrl": {
      "type": "string"
    },
    "pinterestUrl": {
      "type": "string"
    },
    "menuItem": {
      "type": "component",
      "component": "footer.footer-menu-items",
      "repeatable": true
    },
    "location": {
      "type": "component",
      "component": "footer.global-locations",
      "repeatable": true
    },
    "newsletterHeading": {
      "type": "string"
    },
