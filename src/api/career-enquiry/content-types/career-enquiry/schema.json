{
  "kind": "collectionType",
  "collectionName": "career_enquiries",
  "info": {
    "singularName": "career-enquiry",
    "pluralName": "career-enquiries",
    "displayName": "Career Enquiry"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
