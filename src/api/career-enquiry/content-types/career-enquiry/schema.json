    "fullName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phoneNumber": {
      "type": "string",
      "required": true
    },
    "currentCTC": {
      "type": "string",
      "required": true
    },
    "experience": {
      "type": "string",
      "required": true
    },
    "currentLocation": {
      "type": "string",
      "required": true
    },
    "resume": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "videos",
        "audios",
        "files"
      ]
    },
    "applyingFor": {
      "type": "string",
      "required": true
    }
  }
}
