{
  "kind": "collectionType",
  "collectionName": "software_pages",
  "info": {
    "singularName": "software-page",
    "pluralName": "software-pages",
    "displayName": "Software Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "softwareName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "softwareName",
      "required": true
    },
    "sectionHeader": {
      "type": "component",
      "component": "shared.section-header",
      "repeatable": false
    },
    "banner": {
      "type": "component",
      "component": "software-page.banner",
      "repeatable": false
    },
    "softwareImages": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "ctaSection": {
      "type": "component",
      "component": "shared.cta",
      "repeatable": false
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
