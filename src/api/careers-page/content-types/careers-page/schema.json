      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "vacancyDetails": {
      "type": "component",
      "component": "careers-page.vacancy",
      "repeatable": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
